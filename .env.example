# Copie de reference — les vraies valeurs sont configurees dans Vercel (jamais dans git)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...   # fourni automatiquement par le store Blob lie au projet Vercel
RESEND_API_KEY=re_...                      # cle API Resend
CONTACT_TO_EMAIL=contact@exemple.com       # email qui recoit les demandes
CONTACT_FROM_EMAIL=NISSI Contact <onboarding@resend.dev>

# --- Back office (/admin) ---
# Choisissez un identifiant et un mot de passe forts puis ajoutez-les dans Vercel.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-moi-en-production
# Cle de signature des cookies d'admin (obligatoire en production, sinon une valeur par defaut est utilisee).
# Generez-en une avec :  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_JWT_SECRET=changez-moi-en-production
